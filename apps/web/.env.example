# Kakao Maps JavaScript key
# Register http://localhost:5173 as a JavaScript SDK domain.
VITE_KAKAO_MAP_KEY=

# Supabase Auth public client settings
# Use Project Settings > API > Project URL and anon public key.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# MVP ID/PW mode maps a user ID to an internal auth email.
# Keep email confirmation disabled for this local MVP, or switch to real email auth later.
VITE_AUTH_EMAIL_DOMAIN=polling-in-run.local
